# Supabase Auth (required for real authentication)
# When these are not set, the app falls back to the legacy custom session system.
NEXT_PUBLIC_SUPABASE_URL=https://ikcfshaonadcnlgcnecx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Site URL (used for OAuth redirect URLs and password reset links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Media storage base URL (set to Supabase project URL to serve seed media from Storage)
# When unset, seed catalog uses external CDN fallbacks (picsum, soundhelix, etc.)
# NEXT_PUBLIC_MEDIA_STORAGE_BASE=https://ikcfshaonadcnlgcnecx.supabase.co

# Postgres connection (used by BFF persistence layer)
DATABASE_URL=postgresql://postgres:your-password@db.ikcfshaonadcnlgcnecx.supabase.co:5432/postgres
