# ─────────────────────────────────────────────────────
# oneofakinde-os — environment configuration
# ─────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
#   cp .env.local.example .env.local

# ── Supabase ─────────────────────────────────────────
# Required for real authentication. When unset, the app
# falls back to the legacy custom session system.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Site URL ─────────────────────────────────────────
# Used for OAuth redirect URLs, password reset links,
# and OpenGraph metadataBase.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────
# Postgres connection for the BFF persistence layer.
# When set, enables the "postgres" backend. When unset,
# data is stored in .data/ook-bff-db.json (file backend).
# Run: npm run db:setup   to bootstrap schema + seed data.
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# Optional: override the persistence backend explicitly.
# Values: "file" | "postgres" (auto-detected from DATABASE_URL)
# OOK_BFF_PERSISTENCE_BACKEND=postgres

# Optional: connection pool size (default: 10)
# OOK_BFF_DATABASE_POOL_MAX=10

# Optional: enable SSL for Postgres connections
# OOK_BFF_DATABASE_SSL=require

# ── Stripe ───────────────────────────────────────────
# Required for real payment processing. When unset, the
# checkout flow uses the built-in manual payment provider.
# STRIPE_SECRET_KEY=sk_test_your-key-here

# Webhook secret for verifying Stripe webhook signatures.
# Configure the webhook endpoint in Stripe dashboard:
#   URL: https://your-domain.com/api/v1/payments/webhooks/stripe
#   Events: checkout.session.completed, payment_intent.succeeded
# STRIPE_WEBHOOK_SECRET=whsec_your-secret-here

# Optional: tolerance window for webhook signature verification (seconds)
# STRIPE_WEBHOOK_TOLERANCE_SECONDS=300

# ── Media Storage ────────────────────────────────────
# Set to your Supabase project URL to serve media from
# Supabase Storage. When unset, seed catalog uses external
# CDN fallbacks (picsum, soundhelix, etc.).
# Run: npm run seed:storage   to upload demo media assets.
# NEXT_PUBLIC_MEDIA_STORAGE_BASE=https://your-project.supabase.co

# ── Gateway Provider ─────────────────────────────────
# Controls which CommerceGateway implementation is used.
# "mock" — in-memory mock data (default in development)
# "bff"  — HTTP calls to BFF API routes → Postgres
# Auto-detected: "bff" in production, "mock" otherwise.
# OOK_GATEWAY_PROVIDER=mock

# ── Feature Flags ────────────────────────────────────
# Override feature flag stages for development/testing.
# OOK_FF_OVERRIDE_STAGE=beta
